# ---- Database (Postgres) ----
# Used by the API + Prisma. Matches docker-compose.yml.
DATABASE_URL="postgresql://millionpulse:millionpulse@localhost:5432/millionpulse?schema=public"

# ---- Redis (async generation jobs — used from Phase 3) ----
REDIS_URL="redis://localhost:6379"

# ---- Auth ----
# Change these to long random strings in production.
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="30d"

# ---- API ----
API_PORT=4000
# Comma-separated allowed origins for CORS (the web app).
WEB_ORIGIN="http://localhost:5173"

# ---- Web (Vite) ----
# Where the frontend finds the API.
VITE_API_URL="http://localhost:4000"
